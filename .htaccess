<IfModule mod_rewrite.c>
  DirectorySlash Off
  RewriteEngine On
 
  # Redirect to HTTPS
  RewriteCond %{HTTPS} off
  RewriteRule ^(.*)$ https://%{HTTP_HOST}/$1 [R=301,L]
 
  # Redirect non-www to www
  RewriteCond %{HTTP_HOST} ^afsyacht\.com\.tr [NC]
  RewriteRule ^(.*)$ https://www.afsyacht.com.tr/$1 [L,R=301]

  # SEO Redirects for removed /koleksiyon and /urunler routes
  RewriteRule ^koleksiyon/?$ /usturmacalar [R=301,L]
  RewriteRule ^urunler/afs-thetis/?$ /usturmaca-askisi/afs-thetis [R=301,L]
  RewriteRule ^urunler/afs-pontos/?$ /usturmaca-askisi/afs-pontos [R=301,L]
  RewriteRule ^urunler/afs-argos/?$ /usturmaca-askisi/afs-argos [R=301,L]
  RewriteRule ^urunler/afs-usturmaca-tip-1/?$ /usturmacalar/afs-usturmaca-tip-1 [R=301,L]
  RewriteRule ^urunler/afs-usturmaca-kilifi/?$ /usturmaca-kiliflari/afs-usturmaca-kilifi [R=301,L]
  RewriteRule ^urunler/afs-koc-boynuzu/?$ /koc-boynuzu/afs-koc-boynuzu [R=301,L]
  RewriteRule ^urunler/afs-bot-baglama-askisi/?$ /bot-baglama-askisi/afs-bot-baglama-askisi [R=301,L]
  RewriteRule ^urunler/afs-usturmaca-baglama-halati-tip-1/?$ /usturmaca-baglama-halati/afs-usturmaca-baglama-halati-tip-1 [R=301,L]
  RewriteRule ^urunler/afs-usturmaca-baglama-halati-tip-2/?$ /usturmaca-baglama-halati/afs-usturmaca-baglama-halati-tip-2 [R=301,L]
 
  RewriteRule ^([^/]+)/$ /$1.html [L]
  RewriteRule ^([^/]+)/([^/]+)/$ /$1/$2.html [L]
  RewriteRule ^([^/]+)/([^/]+)/([^/]+)/$ /$1/$2/$3.html [L]
  RewriteRule ^([^/]+)/([^/]+)/([^/]+)/([^/]+)/$ /$1/$2/$3/$4.html [L]
 
  # Remove trailing slashes if not a directory
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^(.*)/$ /$1 [L,R=301]
 
  RewriteRule ^([^/]+)/$ $1.html [L]
  RewriteRule ^([^/]+)/([^/]+)/$ /$1/$2.html [L]
  RewriteRule ^([^/]+)/([^/]+)/([^/]+)/$ /$1/$2/$3.html [L]
 
  # Serve .html files if they exist (handling extensionless URLs)
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_FILENAME}.html -f
  RewriteRule ^(.*)$ $1.html [L]
 
  # Custom 404 Page
  ErrorDocument 404 /404.html
</IfModule>
 
# Cache Control for Static Assets
<IfModule mod_expires.c>
  ExpiresActive on
  ExpiresByType image/jpg "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/gif "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType text/css "access plus 1 month"
  ExpiresByType application/pdf "access plus 1 month"
  ExpiresByType text/javascript "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  ExpiresByType application/x-javascript "access plus 1 month"
  ExpiresByType application/x-shockwave-flash "access plus 1 month"
  ExpiresByType image/x-icon "access plus 1 year"
  ExpiresDefault "access plus 2 days"
</IfModule>